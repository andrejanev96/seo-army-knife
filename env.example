# Copy to .env.local (gitignored) and fill in.

# URL of the Cloudflare Worker crawler proxy deployed from worker/
# (see worker/README.md). When set, fetch-using tools (OG Tag Checker,
# upcoming redirect-chain / status-check tools) try this proxy first
# and fall back to public CORS proxies (allorigins, corsproxy, codetabs)
# if it errors or 502s.
#
# Leave blank to use only the public proxies (which can't get past
# Cloudflare-protected sites).
VITE_CRAWLER_PROXY_URL=

# Legacy alias — still honored as a fallback for backwards compatibility
# with the original og-checker-only deployment. Prefer VITE_CRAWLER_PROXY_URL
# for new setups. If both are set, VITE_CRAWLER_PROXY_URL wins.
# VITE_OG_PROXY_URL=
