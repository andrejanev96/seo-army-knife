# Copy to .env.local (gitignored) and fill in.

# URL of the Cloudflare Worker proxy deployed from worker/ (see worker/README.md).
# When set, the OG Tag Checker tries this proxy first and falls back to the public
# CORS proxies (allorigins, corsproxy, codetabs) if it errors or 502s.
#
# Leave blank to use only the public proxies (which can't get past Cloudflare).
VITE_OG_PROXY_URL=
